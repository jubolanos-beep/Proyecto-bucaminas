struct Jugador { //ES COMO UNA LISTA DE PYTHON, GUARDAMOS VARIAS VARIABLES DE DIFERENTES TIPOS EN JUGADOR
		string nombre;
		int tiempo;
		int puntaje;
	};
int calcularPuntaje(int tiempo, int dificultad){  //FUNCION PARA CALCULAR EL PUNTAJE
	int base;
	if(dificultad == 1) base ==1000;
	else if(dificultad == 2) base == 2000;
	else base == 3000;
	return base - tiempo*10;
}
void guardarJugador(Jugador ranking[], int &n, string nombre, int tiempo, int puntaje){ //SE GUARDA EL NOMBRE DEL JUGADOR PARA LA LISTA DE LOS PUNTAJES
	ranking[n].nombre = nombre;
	ranking[n].tiempo = tiempo;
	ranking[n].puntaje = puntaje;
	n++;
}
void ordenarRanking(Jugador ranking[], int n){ //SI EL NUEVO JUGADOR REGISTRADO GANO EN MENOR TIEMPO ENTONCES OCUPARA LA POSICION MENOR(MAS ARRIBA EN EL RANKING)
	for(int i = 0; i < n - 1; i++){
		for(int j = i + 1; j < n; j++){
			if(ranking[j].tiempo < ranking[i].tiempo){
				swap(ranking[i], ranking[j]);
			}
		}
	}
}
void mostrarRanking(Jugador ranking[], int n){ //DESPUES DE ORGANIZAR EL RANKING AHORA SE MOSTRARA
